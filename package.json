{
  "name": "fase-ai",
  "version": "5.0.1",
  "description": "FASE. - Framework de Automação Sem Enrolação. Brazilian Portuguese translation of get-shit-done for AI coding assistants",
  "type": "module",
  "bin": {
    "fase-ai": "dist/install.js",
    "fase": "dist/install.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/isaaceliape/FASE.git"
  },
  "keywords": [
    "fase",
    "get-shit-done",
    "gsd",
    "ai",
    "automation",
    "claude-code",
    "opencode",
    "gemini",
    "codex",
    "portuguese",
    "brazilian",
    "spec-driven",
    "context-engineering",
    "meta-prompting"
  ],
  "author": "Isaac Eliape",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/isaaceliape/FASE/issues"
  },
  "homepage": "https://github.com/isaaceliape/FASE#readme",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "prepare": "husky install || true",
    "build": "tsc",
    "postbuild": "node scripts/fix-shebangs.mjs && node scripts/sync-version.mjs",
    "postinstall": "node dist/install.js --auto-detect || true",
    "sync-version": "node scripts/sync-version.mjs",
    "verificar-pacote": "npm pack --dry-run",
    "verificar-instalacao": "node dist/verificar-instalacao.js",
    "build-docs": "node build-docs.cjs",
    "lint": "eslint src/",
    "format": "prettier --write \"src/**/*.ts\" \"src/**/*.js\" \"scripts/**/*.{mjs,cjs}\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"src/**/*.js\" \"scripts/**/*.{mjs,cjs}\"",
    "test": "mocha test/unit/*.test.cjs test/integration/*.test.cjs",
    "test:unit": "mocha test/unit/*.test.cjs --require ./test/helpers/test-helper.cjs",
    "test:integration": "mocha test/integration/*.test.cjs",
    "test:e2e": "mocha test/e2e/*.test.cjs",
    "test:tmux": "./test/tmux/run-all-tests.sh",
    "test:tmux:smoke": "node test/tmux-runner.cjs --smoke",
    "test:tmux:all": "node test/tmux-runner.cjs --all",
    "test:tmux:interaction": "mocha test/tmux/tui-interaction.test.cjs --timeout 60000",
    "test:all": "npm run test:unit && npm run test:integration",
    "test:coverage": "mocha test/unit/*.test.cjs test/integration/*.test.cjs --reporter json > test-results.json",
    "test:watch": "mocha test/unit/*.test.cjs --watch",
    "test:docker:all": "cd test && bash run-docker-tests.sh --all",
    "test:docker:clean": "cd test && bash run-docker-tests.sh --cleanup",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "eslint": "^10.2.1",
    "husky": "^9.0.0",
    "lint-staged": "^16.4.0",
    "mocha": "^11.7.5",
    "prettier": "^3.8.3",
    "serialize-javascript": "^7.0.5",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.0"
  },
  "dependencies": {
    "marked": "^18.0.2",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{js,jsx,mjs,cjs}": [
      "prettier --write"
    ],
    "package.json": [
      "node -e \"import('./package.json', { with: { type: 'json' } }).then(m => console.log('✓ package.json válido'))\""
    ]
  },
  "files": [
    "dist/",
    "agentes/",
    "comandos/",
    "fase-shared/",
    "README.md"
  ]
}
