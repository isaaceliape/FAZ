{
  "name": "fase-ai",
  "version": "3.0.2",
  "description": "F.A.S.E. - Framework de Automação Sem Enrolação. Brazilian Portuguese translation of get-shit-done for AI coding assistants",
  "bin": {
    "fase-ai": "install.js",
    "fase": "install.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/isaaceliape/FASE.git"
  },
  "keywords": [
    "fase",
    "get-shit-done",
    "gsd",
    "ai",
    "automation",
    "claude-code",
    "opencode",
    "gemini",
    "codex",
    "portuguese",
    "brazilian",
    "spec-driven",
    "context-engineering",
    "meta-prompting"
  ],
  "author": "Isaac Eliape",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/isaaceliape/FASE/issues"
  },
  "homepage": "https://github.com/isaaceliape/FASE#readme",
  "engines": {
    "node": ">=14.0.0"
  },
  "scripts": {
    "verificar-pacote": "npm pack --dry-run",
    "test": "mocha test/*.test.js",
    "test:install": "mocha test/install.test.js",
    "test:providers": "mocha test/providers.test.js",
    "test:integration": "mocha test/integration.test.js",
    "test:docker": "mocha test/docker-test.js",
    "test:edge-cases": "mocha test/edge-cases.test.js",
    "test:watch": "mocha test/*.test.js --watch",
    "test:coverage": "mocha test/*.test.js --reporter json > test-results.json",
    "test:docker:all": "cd test && bash run-docker-tests.sh --all",
    "test:docker:clean": "cd test && bash run-docker-tests.sh --cleanup"
  },
  "devDependencies": {
    "husky": "^9.0.0",
    "lint-staged": "^15.0.0",
    "mocha": "^10.0.0"
  },
  "lint-staged": {
    "package.json": [
      "node -e \"const pkg = require('./package.json'); console.log('✓ package.json válido');\""
    ]
  },
  "files": [
    "lib/",
    "agentes/",
    "comandos/",
    "install.js",
    "verificar-instalacao.js",
    "README.md"
  ]
}
